# ── Assouline ATS API — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Your Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# A secret string you set in BOTH this file AND in Zapier's webhook header
# This prevents unauthorized requests to your webhook
WEBHOOK_SECRET=assouline-ats-2024

# Port (defaults to 3000 if not set)
PORT=3000
